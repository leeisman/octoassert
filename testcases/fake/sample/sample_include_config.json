{
  "id": "sample_include_config",
  "name": "Sample: Include Config",
  "description": "示範從 config/fake.yaml 載入環境設定，再啟動 fake server，讓 test case 不 hardcode endpoint。",
  "order": 3,
  "config": {
    "timeout_ms": 10000
  },
  "steps": [
    {
      "step_id": "1",
      "type": "include",
      "description": "從 config/fake.yaml 載入 http base_url",
      "action": {
        "file_path": "config/fake.yaml"
      },
      "asserts": null,
      "exports": [
        {
          "path": "http.base_url",
          "as": "ctx.base_url"
        }
      ]
    },
    {
      "step_id": "2",
      "type": "fake_http_start",
      "description": "啟動 fake HTTP server on port 18082（與 config 中的 port 對應）",
      "action": {
        "port": 18082,
        "routes": [
          {
            "method": "GET",
            "path": "/status",
            "status": 200,
            "body": {
              "ready": true
            }
          }
        ]
      },
      "asserts": null,
      "exports": [
        {
          "path": "url",
          "as": "ctx.actual_url"
        }
      ]
    },
    {
      "step_id": "3",
      "type": "http_request",
      "description": "使用 ctx.actual_url 呼叫 /status",
      "action": {
        "method": "GET",
        "url": "${ctx.actual_url}/status"
      },
      "asserts": [
        {
          "type": "json_path",
          "path": "status_code",
          "expect": 200
        },
        {
          "type": "json_path",
          "path": "body.ready",
          "expect": true
        }
      ],
      "exports": null
    },
    {
      "step_id": "4",
      "type": "fake_http_stop",
      "description": "stop http",
      "action": {
        "url": "${ctx.actual_url}"
      },
      "asserts": null,
      "exports": null
    }
  ]
}