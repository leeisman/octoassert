{
  "id": "proxy_createroom",
  "name": "Proxy CreateRoom",
  "description": "Fetch the first registered server id from queryserver, then proxy cbm.ClassicalBaccarat/CreateRoom through queryserver.",
  "config": {
    "timeout_ms": 30000
  },
  "steps": [
    {
      "step_id": "1",
      "type": "grpc_unary",
      "description": "",
      "action": {
        "endpoint": "127.0.0.1:50055",
        "service": "management.DistributeServiceManagement",
        "method": "FetchServerList",
        "payload": {}
      },
      "asserts": [
        {
          "type": "json_path",
          "path": "grpc_code",
          "expect": "OK"
        }
      ],
      "exports": [
        {
          "path": "response.servers.0.id",
          "as": "ctx.server_id"
        }
      ]
    },
    {
      "step_id": "2",
      "type": "grpc_unary",
      "description": "CreateRoom via queryserver proxy",
      "action": {
        "endpoint": "127.0.0.1:50055",
        "service": "cbm.ClassicalBaccarat",
        "method": "CreateRoom",
        "payload": {
          "roomName": "octoassert-proxy-room",
          "ruleId": 1,
          "synthesizerId": 1,
          "exposureSize": 100000
        },
        "metadata": {
          "x-server-id": "${ctx.server_id}"
        },
        "proto_files": [
          "../distributeproto/ClassicalBaccaratManagement.proto"
        ]
      },
      "asserts": [
        {
          "type": "json_path",
          "path": "grpc_code",
          "expect": "OK"
        }
      ],
      "exports": [
        {
          "path": "response.roomSerial",
          "as": "ctx.room_serial"
        }
      ]
    },
    {
      "step_id": "3",
      "type": "db_check",
      "description": "Verify CreateRoom inserted the returned room serial into baccarat_room.",
      "action": {
        "driver": "postgres",
        "dsn": "host=127.0.0.1 port=5432 user=baccarat password=666666 dbname=baccarat_game sslmode=disable",
        "sql": "SELECT serial, room_name, rule_id, synthesizer_id, exposure_size FROM baccarat_room WHERE serial = ${ctx.room_serial}"
      },
      "asserts": [
        {
          "type": "json_path",
          "path": "row_count",
          "expect": 1
        },
        {
          "type": "json_path",
          "path": "rows.0.room_name",
          "expect": "octoassert-proxy-room"
        },
        {
          "type": "json_path",
          "path": "rows.0.rule_id",
          "expect": 1
        },
        {
          "type": "json_path",
          "path": "rows.0.synthesizer_id",
          "expect": 1
        },
        {
          "type": "json_path",
          "path": "rows.0.exposure_size",
          "expect": 100000
        }
      ],
      "exports": null
    }
  ]
}